# Web3Forms access key — get one at https://web3forms.com (free, no signup beyond email)
PUBLIC_WEB3FORMS_KEY=YOUR_WEB3FORMS_ACCESS_KEY

# Discord webhook URL — Server Settings → Integrations → Webhooks → New Webhook → Copy URL
PUBLIC_DISCORD_WEBHOOK=https://discord.com/api/webhooks/XXXX/YYYY

# Cal.com username (optional) — leave blank to hide the booking widget
PUBLIC_CAL_USERNAME=
