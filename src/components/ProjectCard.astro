---
import { localePath, type Lang } from '~/i18n';
interface Props {
  lang: Lang;
  project: {
    slug: string;
    title: { en: string; sl: string };
    short: { en: string; sl: string };
    date: string;
    category: string;
    materials?: string[];
  };
}
const { lang, project } = Astro.props;
const categoryLabel: Record<string, { en: string; sl: string }> = {
  cad: { en: 'CAD', sl: 'CAD' },
  iot: { en: 'IoT', sl: 'IoT' },
  embedded: { en: 'Embedded', sl: 'Vgrajeno' },
  mechanical: { en: 'Mechanical', sl: 'Mehansko' }
};
---
<a href={localePath(lang, `/portfolio/${project.slug}`)}
   class="group block rounded-xl border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900/50 hover:border-accent-400 dark:hover:border-accent-500 hover:shadow-lg transition-all overflow-hidden">
  <div class="aspect-[4/3] relative bg-gradient-to-br from-ink-100 via-ink-50 to-accent-50 dark:from-ink-800 dark:via-ink-900 dark:to-accent-900/30 flex items-center justify-center">
    <span class="font-display text-3xl text-ink-300 dark:text-ink-700 select-none">{project.slug.split('-').map(w => w[0]?.toUpperCase()).join('')}</span>
    <span class="absolute top-3 left-3 text-[10px] uppercase tracking-wider px-2 py-1 rounded bg-white/80 dark:bg-ink-950/70 text-ink-700 dark:text-ink-200 backdrop-blur">
      {categoryLabel[project.category]?.[lang] ?? project.category}
    </span>
    <span class="absolute top-3 right-3 text-[10px] text-ink-500 dark:text-ink-400">{project.date}</span>
  </div>
  <div class="p-5">
    <h3 class="font-display text-lg font-bold leading-tight mb-1 group-hover:text-accent-600 dark:group-hover:text-accent-300 transition-colors">{project.title[lang]}</h3>
    <p class="text-sm text-ink-500 dark:text-ink-400 leading-relaxed">{project.short[lang]}</p>
  </div>
</a>
