---
import ServiceIcon from './ServiceIcon.astro';
import { t, localePath, type Lang } from '~/i18n';
interface Props {
  lang: Lang;
  service: { slug: string; icon: string; title: { en: string; sl: string }; short: { en: string; sl: string } };
  accent?: string;
}
const { lang, service, accent } = Astro.props;
const dict = t(lang);
---
<a href={localePath(lang, `/services#${service.slug}`)}
   data-tilt="6"
   style={accent ? `--kartica-akcent: ${accent}` : undefined}
   class="premium-kartica group relative block p-6 hover:border-accent-400 dark:hover:border-accent-500">
  <div class="flex items-center justify-between mb-4">
    <div class="w-11 h-11 rounded-lg bg-accent-50 dark:bg-accent-900/40 text-accent-600 dark:text-accent-300 flex items-center justify-center">
      <ServiceIcon name={service.icon} />
    </div>
    <span class="text-[11px] uppercase tracking-wider text-ink-400">{dict.services.quote_badge}</span>
  </div>
  <h3 class="font-display text-xl font-bold leading-tight mb-2">{service.title[lang]}</h3>
  <p class="text-sm text-ink-500 dark:text-ink-400 leading-relaxed">{service.short[lang]}</p>
  <span class="mt-4 inline-flex items-center text-sm font-medium text-accent-600 dark:text-accent-300">
    {dict.services.cta}
    <svg class="ml-1 w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
  </span>
</a>
