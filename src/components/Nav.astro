---
import { t, localePath, altLang, type Lang } from '~/i18n';
import Logo from './Logo.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const dict = t(lang);
const url = Astro.url;
const pathNoLang = url.pathname
  .replace(import.meta.env.BASE_URL?.replace(/\/$/, '') ?? '', '')
  .replace(/^\/(en|sl)(?=\/|$)/, '') || '/';
const otherLang = altLang(lang);
const otherHref = localePath(otherLang, pathNoLang);

const links = [
  { href: localePath(lang, '/'),          label: dict.nav.home },
  { href: localePath(lang, '/services'),  label: dict.nav.services },
  { href: localePath(lang, '/portfolio'), label: dict.nav.portfolio },
  { href: localePath(lang, '/skills'),    label: dict.nav.skills },
  { href: localePath(lang, '/about'),     label: dict.nav.about }
];
const orderHref = localePath(lang, '/order');
---
<header class="premium-nav sticky top-0 z-40">
  <nav class="mx-auto max-w-6xl px-5 h-16 flex items-center justify-between gap-4">
    <a href={localePath(lang, '/')} class="flex items-center gap-2.5 font-display text-lg tracking-tight font-bold">
      <Logo size={32} />
      <span class="premium-logo">Nace Kepa</span>
    </a>
    <ul class="hidden md:flex items-center gap-1 text-sm">
      {links.map((l) => (
        <li>
          <a href={l.href} class="premium-nav-link px-3 py-2 rounded-md">
            {l.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="flex items-center gap-2">
      <a href={otherHref}
         class="text-xs font-medium px-2.5 py-1.5 rounded-md border border-ink-200 dark:border-ink-700 hover:bg-ink-100 dark:hover:bg-ink-800/60 transition-colors"
         aria-label={dict.lang.label}>
        {otherLang.toUpperCase()}
      </a>
      <a href={orderHref} data-magnetic="0.3"
         class="premium-gumb hidden sm:inline-flex items-center text-sm px-4 py-1.5">
        {dict.nav.order}
      </a>
    </div>
  </nav>
</header>

