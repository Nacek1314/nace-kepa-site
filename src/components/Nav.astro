---
import { t, localePath, altLang, type Lang } from '~/i18n';
import Logo from './Logo.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const dict = t(lang);
const url = Astro.url;
const pathNoLang = url.pathname
  .replace(import.meta.env.BASE_URL?.replace(/\/$/, '') ?? '', '')
  .replace(/^\/(en|sl)(?=\/|$)/, '') || '/';
const otherLang = altLang(lang);
const otherHref = localePath(otherLang, pathNoLang);

const links = [
  { href: localePath(lang, '/'),          label: dict.nav.home },
  { href: localePath(lang, '/services'),  label: dict.nav.services },
  { href: localePath(lang, '/portfolio'), label: dict.nav.portfolio },
  { href: localePath(lang, '/skills'),    label: dict.nav.skills },
  { href: localePath(lang, '/about'),     label: dict.nav.about }
];
const orderHref = localePath(lang, '/order');
---
<header class="premium-nav sticky top-0 z-40">
  <nav class="mx-auto max-w-6xl px-5 h-16 flex items-center justify-between gap-4">
    <a href={localePath(lang, '/')} class="flex items-center gap-2.5 font-display text-lg tracking-tight font-bold">
      <Logo size={32} />
      <span class="premium-logo">Nace Kepa</span>
    </a>
    <ul class="hidden md:flex items-center gap-1 text-sm">
      {links.map((l) => (
        <li>
          <a href={l.href} class="premium-nav-link px-3 py-2 rounded-md">
            {l.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="flex items-center gap-2">
      <a href={otherHref}
         class="text-xs font-medium px-2.5 py-1.5 rounded-md border border-ink-200 dark:border-ink-700 hover:bg-ink-100 dark:hover:bg-ink-800/60 transition-colors"
         aria-label={dict.lang.label}>
        {otherLang.toUpperCase()}
      </a>
      <a href={orderHref} data-magnetic="0.3"
         class="premium-gumb hidden sm:inline-flex items-center text-sm px-4 py-1.5">
        {dict.nav.order}
      </a>
      <button type="button"
              id="mobile-nav-toggle"
              class="md:hidden inline-flex items-center justify-center w-9 h-9 rounded-md border border-ink-200 dark:border-ink-700 hover:bg-ink-100 dark:hover:bg-ink-800/60 transition-colors"
              aria-label="Menu"
              aria-expanded="false"
              aria-controls="mobile-nav-panel">
        <svg class="mobile-icon-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg class="mobile-icon-close hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile slide-down panel -->
  <div id="mobile-nav-panel"
       class="md:hidden hidden border-t border-ink-200/60 dark:border-ink-800/60 bg-ink-950/95 backdrop-blur-md">
    <ul class="px-5 py-4 flex flex-col gap-1 text-base">
      {links.map((l) => (
        <li>
          <a href={l.href}
             class="block px-3 py-2.5 rounded-md text-ink-200 hover:bg-ink-800/60 hover:text-white transition-colors">
            {l.label}
          </a>
        </li>
      ))}
      <li class="pt-2 mt-2 border-t border-ink-800/60">
        <a href={orderHref}
           class="block px-3 py-2.5 rounded-md bg-accent-600 text-white text-center font-medium hover:bg-accent-700 transition-colors">
          {dict.nav.order}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  function setupMobileNav() {
    const btn = document.getElementById('mobile-nav-toggle');
    const panel = document.getElementById('mobile-nav-panel');
    if (!btn || !panel || btn.dataset.bound) return;
    btn.dataset.bound = '1';
    const open = () => { panel.classList.remove('hidden'); btn.setAttribute('aria-expanded', 'true'); btn.querySelector('.mobile-icon-open')?.classList.add('hidden'); btn.querySelector('.mobile-icon-close')?.classList.remove('hidden'); };
    const close = () => { panel.classList.add('hidden'); btn.setAttribute('aria-expanded', 'false'); btn.querySelector('.mobile-icon-open')?.classList.remove('hidden'); btn.querySelector('.mobile-icon-close')?.classList.add('hidden'); };
    btn.addEventListener('click', () => {
      if (panel.classList.contains('hidden')) open(); else close();
    });
    // Close when a link is clicked
    panel.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
    // Close on Escape
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
  }
  setupMobileNav();
  document.addEventListener('astro:page-load', setupMobileNav);
</script>

