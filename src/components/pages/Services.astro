---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ServiceIcon from '~/components/ServiceIcon.astro';
import { t, localePath, type Lang } from '~/i18n';
import { getCollection } from 'astro:content';

interface Props { lang: Lang }
const lang: Lang = (Astro.props as any).lang ?? 'en';
const dict = t(lang);
const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout lang={lang} title={dict.services.heading}>
  <section class="mx-auto max-w-4xl px-5 py-16">
    <h1 class="font-display font-bold text-4xl sm:text-5xl tracking-tight">{dict.services.heading}</h1>
    <p class="mt-3 text-ink-500 dark:text-ink-400 max-w-2xl">{dict.services.sub}</p>
  </section>

  <section class="mx-auto max-w-4xl px-5 pb-20 space-y-10">
    {services.map((s) => (
      <article id={s.data.slug} class="rounded-2xl border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900/50 p-8 scroll-mt-24">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-lg bg-accent-50 dark:bg-accent-900/40 text-accent-600 dark:text-accent-300 flex items-center justify-center shrink-0">
            <ServiceIcon name={s.data.icon} />
          </div>
          <div class="flex-1">
            <div class="flex items-center justify-between flex-wrap gap-3">
              <h2 class="font-display text-2xl font-bold">{s.data.title[lang]}</h2>
              <span class="text-[11px] uppercase tracking-wider px-2.5 py-1 rounded bg-accent-50 dark:bg-accent-900/40 text-accent-700 dark:text-accent-200">
                {dict.services.quote_badge}
              </span>
            </div>
            <p class="mt-3 text-ink-600 dark:text-ink-300 leading-relaxed">{s.data.long[lang]}</p>
            <div class="grid sm:grid-cols-2 gap-6 mt-6">
              <div>
                <p class="text-xs uppercase tracking-wider text-ink-500 mb-2">{dict.services.deliverables}</p>
                <ul class="space-y-1.5 text-sm">
                  {s.data.deliverables[lang].map((d: string) => (
                    <li class="flex gap-2"><span class="text-accent-500 mt-0.5">▸</span>{d}</li>
                  ))}
                </ul>
              </div>
              <div>
                <p class="text-xs uppercase tracking-wider text-ink-500 mb-2">{dict.services.needs}</p>
                <ul class="space-y-1.5 text-sm">
                  {s.data.needs[lang].map((d: string) => (
                    <li class="flex gap-2"><span class="text-ink-400 mt-0.5">▸</span>{d}</li>
                  ))}
                </ul>
              </div>
            </div>
            <a href={localePath(lang, '/order')} class="mt-6 inline-flex items-center text-sm font-medium px-4 py-2 rounded-md bg-accent-600 text-white hover:bg-accent-700 transition-colors">
              {dict.services.cta} →
            </a>
          </div>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
