---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SkillsCloud from '~/components/SkillsCloud.astro';
import { t, localePath, type Lang } from '~/i18n';
import { getCollection } from 'astro:content';

interface Props { lang: Lang }
const lang: Lang = (Astro.props as any).lang ?? 'en';
const dict = t(lang);
const faq = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout lang={lang} title={dict.about.heading}>
  <section class="mx-auto max-w-3xl px-5 py-16">
    <h1 class="font-display font-bold text-4xl sm:text-5xl tracking-tight">{dict.about.heading}</h1>
    <p class="mt-3 text-ink-500 dark:text-ink-400">{dict.about.sub}</p>

    <div class="mt-8 space-y-4 text-ink-700 dark:text-ink-200 leading-relaxed">
      <p>
        {lang === 'sl'
          ? 'Sem Nace Kepa, dijak Šolskega centra Kranj iz Škofje Loke. Že štiri leta delam s SolidWorksom, dve leti tiskam na Bambu Lab P1S, in pišem firmware za ESP32, ko mi naprava reče, da hoče delati. Tu je studio, ne agencija — vsak projekt prevzamem osebno.'
          : 'I am Nace Kepa, a student at Šolski center Kranj, based in Škofja Loka. Four years in SolidWorks, two years on a Bambu Lab P1S, and ESP32 firmware whenever a device asks for one. This is a studio, not an agency — every project goes through one engineer.'}
      </p>
      <p>
        {lang === 'sl'
          ? 'Močna stran ni en sam izdelek; je celota — od mehanike prek elektronike do firmware-ja in končnega sestavljanja. Pametna hranilnica, dispenzor za koktajle in zaponka za nahrbtnik so živi dokazi te kombinacije.'
          : 'The point is not any single discipline — it is the combination. Mechanics, electronics, firmware, and final assembly under one roof. The smart piggy bank, the cocktail dispenser, and the engineered backpack buckle are the working proof.'}
      </p>
    </div>

    <dl class="mt-10 grid sm:grid-cols-2 gap-6 text-sm">
      <div>
        <dt class="text-xs uppercase tracking-wider text-ink-500">{lang === 'sl' ? 'Lokacija' : 'Location'}</dt>
        <dd class="font-medium mt-1">{dict.about.based_in}</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wider text-ink-500">{lang === 'sl' ? 'Šola' : 'School'}</dt>
        <dd class="font-medium mt-1">{dict.about.studying_at}</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wider text-ink-500">{dict.about.languages}</dt>
        <dd class="font-medium mt-1">Slovenščina · English</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wider text-ink-500">{dict.about.tools}</dt>
        <dd class="mt-2"><SkillsCloud /></dd>
      </div>
    </dl>
  </section>

  <section class="mx-auto max-w-3xl px-5 py-12">
    <h2 class="font-display text-2xl font-bold mb-6">{lang === 'sl' ? 'Pogosta vprašanja' : 'FAQ'}</h2>
    <dl class="space-y-2">
      {faq.map((f) => (
        <details class="group rounded-lg border border-ink-200 dark:border-ink-800 p-4 open:bg-ink-50 dark:open:bg-ink-900/50">
          <summary class="cursor-pointer list-none flex justify-between items-center font-medium">
            <span>{f.data.q[lang]}</span>
            <span class="text-ink-400 group-open:rotate-45 transition-transform">＋</span>
          </summary>
          <p class="mt-3 text-sm text-ink-600 dark:text-ink-300 leading-relaxed">{f.data.a[lang]}</p>
        </details>
      ))}
    </dl>
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-20">
    <a href={localePath(lang, '/order')}
       class="block rounded-xl border-2 border-dashed border-accent-400 dark:border-accent-700 p-8 text-center hover:bg-accent-50/50 dark:hover:bg-accent-900/20 transition-colors">
      <p class="font-display text-xl font-bold">{dict.home.cta_heading}</p>
      <p class="mt-1 text-sm text-ink-500 dark:text-ink-400">{dict.home.cta_sub}</p>
      <span class="mt-4 inline-flex items-center text-sm font-medium text-accent-600 dark:text-accent-300">{dict.nav.order} →</span>
    </a>
  </section>
</BaseLayout>
