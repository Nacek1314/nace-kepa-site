---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SkillsCloud from '~/components/SkillsCloud.astro';
import PrintBedVisualizer from '~/components/PrintBedVisualizer';
import { t, type Lang } from '~/i18n';
import { getCollection } from 'astro:content';

interface Props { lang: Lang }
const lang: Lang = (Astro.props as any).lang ?? 'en';
const dict = t(lang);
const skills = (await getCollection('skills')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout lang={lang} title={dict.skills.heading}>
  <section class="mx-auto max-w-4xl px-5 py-16">
    <h1 class="font-display font-bold text-4xl sm:text-5xl tracking-tight">{dict.skills.heading}</h1>
    <p class="mt-3 text-ink-500 dark:text-ink-400 max-w-2xl">{dict.skills.sub}</p>
  </section>

  <section class="mx-auto max-w-4xl px-5 pb-12">
    <SkillsCloud />
  </section>

  <section class="mx-auto max-w-4xl px-5 pb-12 space-y-6">
    {skills.map((s) => (
      <article class="rounded-xl border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900/50 p-6">
        <h2 class="font-display text-xl font-bold">{s.data.title[lang]}</h2>
        <p class="mt-2 text-ink-600 dark:text-ink-300 leading-relaxed">{s.data.description[lang]}</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          {s.data.items.map((it: string) => <span class="text-xs px-2 py-1 rounded-md bg-ink-100 dark:bg-ink-800/60">{it}</span>)}
        </div>
      </article>
    ))}
  </section>

  <section class="mx-auto max-w-4xl px-5 pb-20">
    <PrintBedVisualizer client:visible labels={{
      title: lang === 'sl' ? 'Preverjanje velikosti za tiskalnik (Bambu Lab P1S, 256 × 256 × 256 mm)' : 'Print-bed fit check (Bambu Lab P1S, 256 × 256 × 256 mm)',
      x: lang === 'sl' ? 'Širina X (mm)' : 'Width X (mm)',
      y: lang === 'sl' ? 'Globina Y (mm)' : 'Depth Y (mm)',
      z: lang === 'sl' ? 'Višina Z (mm)' : 'Height Z (mm)',
      fits: lang === 'sl' ? 'Gre v en kos' : 'Fits in one piece',
      over: lang === 'sl' ? 'Prevelik — bo razdeljen in zlepljen' : 'Too large — will be split and bonded'
    }} />
  </section>
</BaseLayout>
