---
import BaseLayout from '~/layouts/BaseLayout.astro';
import OrderWizard from '~/components/OrderWizard';
import { t, type Lang } from '~/i18n';

interface Props { lang: Lang }
const lang: Lang = (Astro.props as any).lang ?? 'en';
const dict = t(lang);
const contactEmail = 'kepanace@gmail.com';
// Optional: when set, quote requests are emailed straight to the owner via
// Web3Forms (no mail client needed). See .env.example for setup. The form
// gracefully falls back to mailto: when this is empty.
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';
---
<BaseLayout lang={lang} title={dict.order.heading}>
  <section class="mx-auto max-w-3xl px-5 py-16">
    <h1 class="font-display font-bold text-4xl sm:text-5xl tracking-tight">{dict.order.heading}</h1>
    <p class="mt-3 text-ink-500 dark:text-ink-400 max-w-2xl">{dict.order.sub}</p>
    <p class="mt-2 text-xs text-ink-400 dark:text-ink-500">
      {web3formsKey
        ? (lang === 'sl'
            ? 'Brez prijave — povpraševanje pošljem naravnost v nabiralnik, varno in s sledilno kodo.'
            : 'No sign-up — your request is delivered straight to my inbox, securely, with a tracking code.')
        : (lang === 'sl'
            ? 'Brez prijave, brez zunanjih storitev — povpraševanje se odpre v tvojem e-poštnem odjemalcu.'
            : 'No sign-up, no third-party service — your request opens in your own email client.')}
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-20">
    <OrderWizard client:load lang={lang} dict={dict} contactEmail={contactEmail} web3formsKey={web3formsKey} />
  </section>
</BaseLayout>
