---
import BaseLayout from '~/layouts/BaseLayout.astro';
import OrderWizard from '~/components/OrderWizard';
import { t, type Lang } from '~/i18n';

interface Props { lang: Lang }
const lang: Lang = (Astro.props as any).lang ?? 'en';
const dict = t(lang);
const contactEmail = 'kepanace@gmail.com';
---
<BaseLayout lang={lang} title={dict.order.heading}>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-accent-50/60 via-transparent to-transparent dark:from-accent-900/20"></div>
    <div class="mx-auto max-w-3xl px-5 py-16">
      <div class="flex items-center gap-3">
        <span class="h-px w-10 bg-accent-500/70"></span>
        <span class="text-xs uppercase tracking-[0.2em] text-accent-600 dark:text-accent-300">
          {lang === 'sl' ? 'Povpraševanje' : 'Project brief'}
        </span>
      </div>
      <h1 class="font-display font-bold text-4xl sm:text-5xl tracking-tight mt-5">{dict.order.heading}</h1>
      <p class="mt-3 text-ink-500 dark:text-ink-400 max-w-2xl">{dict.order.sub}</p>
      <p class="mt-2 text-xs text-ink-400 dark:text-ink-500">
        {lang === 'sl'
          ? 'Brez prijave, brez zunanjih storitev — povpraševanje se odpre v tvojem e-poštnem odjemalcu.'
          : 'No sign-up, no third-party service — your request opens in your own email client.'}
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-20">
    <OrderWizard client:load lang={lang} dict={dict} contactEmail={contactEmail} />
  </section>
</BaseLayout>
