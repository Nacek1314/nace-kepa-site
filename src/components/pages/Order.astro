---
import BaseLayout from '~/layouts/BaseLayout.astro';
import OrderWizard from '~/components/OrderWizard';
import { t, type Lang } from '~/i18n';

interface Props { lang: Lang }
const lang: Lang = (Astro.props as any).lang ?? 'en';
const dict = t(lang);
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? 'YOUR_WEB3FORMS_ACCESS_KEY';
const discordWebhook = import.meta.env.PUBLIC_DISCORD_WEBHOOK ?? '';
const calUsername = import.meta.env.PUBLIC_CAL_USERNAME ?? '';
---
<BaseLayout lang={lang} title={dict.order.heading}>
  <section class="mx-auto max-w-3xl px-5 py-16">
    <h1 class="font-display font-bold text-4xl sm:text-5xl tracking-tight">{dict.order.heading}</h1>
    <p class="mt-3 text-ink-500 dark:text-ink-400 max-w-2xl">{dict.order.sub}</p>
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-20">
    <OrderWizard client:load lang={lang} dict={dict} web3formsKey={web3formsKey} discordWebhook={discordWebhook} />
  </section>

  {calUsername && (
    <section class="mx-auto max-w-3xl px-5 pb-20">
      <div class="rounded-xl border border-ink-200 dark:border-ink-800 p-6">
        <p class="font-display text-lg font-bold">
          {lang === 'sl' ? 'Raje pogovor v živo? Rezerviraj 15-minutni klic.' : 'Prefer to talk it through? Book a 15-minute call.'}
        </p>
        <a href={`https://cal.com/${calUsername}`} target="_blank" rel="noopener"
           class="mt-3 inline-flex items-center text-sm font-medium px-4 py-2 rounded-md bg-accent-600 text-white hover:bg-accent-700">
          {lang === 'sl' ? 'Rezerviraj na Cal.com' : 'Book on Cal.com'} →
        </a>
      </div>
    </section>
  )}
</BaseLayout>
