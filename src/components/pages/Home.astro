---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ServiceCard from '~/components/ServiceCard.astro';
import ProjectCard from '~/components/ProjectCard.astro';
import ProcessTimeline from '~/components/ProcessTimeline.astro';
import SkillsCloud from '~/components/SkillsCloud.astro';
import { t, localePath, type Lang } from '~/i18n';
import { getCollection } from 'astro:content';

interface Props { lang: Lang }
const lang: Lang = (Astro.props as any).lang ?? 'en';
const dict = t(lang);
const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order).slice(0, 4);

// Editorial Atelier accent cycle
const paleta = ['#5f8396', '#2f4a61', '#6f6558', '#bcb9ac'];
---
<BaseLayout lang={lang}>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-accent-50/60 via-transparent to-transparent dark:from-accent-900/20"></div>
    <div class="mx-auto max-w-6xl px-5 pt-20 pb-24 sm:pt-28 sm:pb-32">
      <div class="flex items-center gap-3 intro-animacija zamik-1">
        <span class="h-px w-10 bg-accent-500/70"></span>
        <p class="text-xs uppercase tracking-[0.2em] text-accent-600 dark:text-accent-300">{dict.hero.eyebrow}</p>
      </div>
      <h1 data-split class="font-display font-bold text-5xl sm:text-6xl lg:text-7xl tracking-tight mt-5 leading-[1.05] waw-shimmer">
        {dict.hero.title}
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-ink-600 dark:text-ink-300 leading-relaxed intro-animacija zamik-3">
        {dict.hero.subtitle}
      </p>
      <div class="mt-8 flex flex-wrap gap-3 intro-animacija zamik-4">
        <a href={localePath(lang, '/order')} data-magnetic="0.4" class="premium-gumb inline-flex items-center px-6 py-3">
          {dict.hero.cta_primary} →
        </a>
        <a href={localePath(lang, '/portfolio')} data-magnetic="0.25" class="inline-flex items-center px-5 py-3 rounded-md border border-ink-300 dark:border-ink-700 hover:bg-ink-100 dark:hover:bg-ink-800/50 font-medium transition-colors">
          {dict.hero.cta_secondary}
        </a>
      </div>
      <!-- Palette stripe -->
      <div class="mt-14 flex items-center gap-1.5 max-w-md intro-animacija zamik-5" aria-hidden="true">
        <span class="h-1.5 flex-1 rounded-full" style="background:#bcb9ac"></span>
        <span class="h-1.5 flex-1 rounded-full" style="background:#5f8396"></span>
        <span class="h-1.5 flex-1 rounded-full" style="background:#2f4a61"></span>
        <span class="h-1.5 flex-1 rounded-full" style="background:#6f6558"></span>
        <span class="h-1.5 flex-1 rounded-full" style="background:#242527"></span>
      </div>
    </div>
  </section>

  <!-- Stats band -->
  <section data-reveal class="mx-auto max-w-6xl px-5 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      <div class="premium-kartica p-6 text-center">
        <div class="font-display text-5xl font-bold tabular-nums" data-counter="6">0</div>
        <div class="mt-2 text-xs uppercase tracking-[0.18em] text-ink-500">{lang === 'sl' ? 'Projektov dostavljenih' : 'Projects shipped'}</div>
      </div>
      <div class="premium-kartica p-6 text-center">
        <div class="font-display text-5xl font-bold tabular-nums" data-counter="48" data-counter-suffix="h">0</div>
        <div class="mt-2 text-xs uppercase tracking-[0.18em] text-ink-500">{lang === 'sl' ? 'Odgovor na povp.' : 'Avg. reply time'}</div>
      </div>
      <div class="premium-kartica p-6 text-center">
        <div class="font-display text-5xl font-bold tabular-nums" data-counter="100" data-counter-suffix="%">0</div>
        <div class="mt-2 text-xs uppercase tracking-[0.18em] text-ink-500">{lang === 'sl' ? 'Lasten delotok' : 'In-house workflow'}</div>
      </div>
    </div>
  </section>

  <!-- Tech marquee -->
  <section data-reveal class="py-8">
    <div class="marquee">
      <div class="marquee__track py-3 text-sm font-medium tracking-wider uppercase text-ink-500 dark:text-ink-400">
        {[
          'SolidWorks', 'Fusion 360', 'TIA Portal', 'KiCad', 'ESP32',
          'Bambu P1S', 'PLA · PETG · Flex', 'STL · STEP', 'MQTT', 'BLE · Wi-Fi',
          'C / C++', 'MicroPython', 'FEA', 'Mold design', 'Composites'
        ].concat([
          'SolidWorks', 'Fusion 360', 'TIA Portal', 'KiCad', 'ESP32',
          'Bambu P1S', 'PLA · PETG · Flex', 'STL · STEP', 'MQTT', 'BLE · Wi-Fi',
          'C / C++', 'MicroPython', 'FEA', 'Mold design', 'Composites'
        ]).map((t) => (
          <span class="inline-flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full" style="background:var(--gradient-akcent)"></span>
            {t}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section data-reveal class="mx-auto max-w-6xl px-5 py-16">
    <div class="flex items-end justify-between gap-6 mb-8">
      <div>
        <span class="section-label">{lang === 'sl' ? 'Storitve' : 'Services'}</span>
        <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mt-3">{dict.home.services_heading}</h2>
        <p class="mt-2 text-ink-500 dark:text-ink-400">{dict.home.services_sub}</p>
      </div>
      <a href={localePath(lang, '/services')} class="hidden sm:inline text-sm text-accent-600 dark:text-accent-300 hover:underline">{dict.nav.services} →</a>
    </div>
    <div class="grid sm:grid-cols-2 gap-4">
      {services.map((s, i) => <ServiceCard lang={lang} service={s.data} accent={paleta[i % paleta.length]} />)}
    </div>
  </section>

  <!-- Process -->
  <section data-reveal class="mx-auto max-w-6xl px-5 py-16">
    <span class="section-label">{lang === 'sl' ? 'Delotok' : 'Workflow'}</span>
    <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mt-3 mb-2">
      {lang === 'sl' ? 'Postopek' : 'Process'}
    </h2>
    <p class="mb-8 text-ink-500 dark:text-ink-400">
      {lang === 'sl' ? 'Od briefa do dostave — osem korakov, en delovni tok.' : 'From brief to delivery — eight steps, one workflow.'}
    </p>
    <ProcessTimeline lang={lang} />
  </section>

  <!-- Projects -->
  <section data-reveal class="mx-auto max-w-6xl px-5 py-16">
    <div class="flex items-end justify-between gap-6 mb-8">
      <div>
        <span class="section-label">{lang === 'sl' ? 'Izbrano' : 'Selected'}</span>
        <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mt-3">{dict.home.projects_heading}</h2>
        <p class="mt-2 text-ink-500 dark:text-ink-400">{dict.home.projects_sub}</p>
      </div>
      <a href={localePath(lang, '/portfolio')} class="hidden sm:inline text-sm text-accent-600 dark:text-accent-300 hover:underline">{dict.nav.portfolio} →</a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {projects.map((p, i) => <ProjectCard lang={lang} project={p.data} accent={paleta[i % paleta.length]} />)}
    </div>
  </section>

  <!-- Skills -->
  <section data-reveal class="mx-auto max-w-6xl px-5 py-16">
    <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mb-2">{dict.home.skills_heading}</h2>
    <p class="mb-8 text-ink-500 dark:text-ink-400">{dict.home.skills_sub}</p>
    <SkillsCloud />
  </section>

  <!-- CTA -->
  <section data-reveal="zoom" class="mx-auto max-w-6xl px-5 py-16">
    <div class="rounded-2xl bg-ink-900 dark:bg-ink-800 text-ink-50 p-10 sm:p-14 relative overflow-hidden">
      <div data-parallax="0.15" class="absolute -top-32 -right-32 w-96 h-96 bg-accent-500/30 rounded-full blur-3xl"></div>
      <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight max-w-xl">{dict.home.cta_heading}</h2>
      <p class="mt-3 text-ink-300 max-w-xl">{dict.home.cta_sub}</p>
      <a href={localePath(lang, '/order')} data-magnetic="0.4" class="premium-gumb mt-6 inline-flex items-center px-6 py-3">
        {dict.home.cta_button} →
      </a>
    </div>
  </section>
</BaseLayout>
