---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ServiceCard from '~/components/ServiceCard.astro';
import ProjectCard from '~/components/ProjectCard.astro';
import ProcessTimeline from '~/components/ProcessTimeline.astro';
import SkillsCloud from '~/components/SkillsCloud.astro';
import { t, localePath, type Lang } from '~/i18n';
import { getCollection } from 'astro:content';

interface Props { lang: Lang }
const lang: Lang = (Astro.props as any).lang ?? 'en';
const dict = t(lang);
const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order).slice(0, 4);
---
<BaseLayout lang={lang}>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-accent-50/60 via-transparent to-transparent dark:from-accent-900/20"></div>
    <div class="mx-auto max-w-6xl px-5 pt-20 pb-24 sm:pt-28 sm:pb-32">
      <p class="text-xs uppercase tracking-[0.2em] text-accent-600 dark:text-accent-300 reveal">{dict.hero.eyebrow}</p>
      <h1 class="font-display font-bold text-5xl sm:text-6xl lg:text-7xl tracking-tight mt-4 leading-[1.05] reveal">
        {dict.hero.title}
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-ink-600 dark:text-ink-300 leading-relaxed reveal">
        {dict.hero.subtitle}
      </p>
      <div class="mt-8 flex flex-wrap gap-3 reveal">
        <a href={localePath(lang, '/order')} class="inline-flex items-center px-5 py-3 rounded-md bg-accent-600 text-white font-medium hover:bg-accent-700 transition-colors">
          {dict.hero.cta_primary} →
        </a>
        <a href={localePath(lang, '/portfolio')} class="inline-flex items-center px-5 py-3 rounded-md border border-ink-300 dark:border-ink-700 hover:bg-ink-100 dark:hover:bg-ink-800/50 font-medium transition-colors">
          {dict.hero.cta_secondary}
        </a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="flex items-end justify-between gap-6 mb-8">
      <div>
        <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight">{dict.home.services_heading}</h2>
        <p class="mt-2 text-ink-500 dark:text-ink-400">{dict.home.services_sub}</p>
      </div>
      <a href={localePath(lang, '/services')} class="hidden sm:inline text-sm text-accent-600 dark:text-accent-300 hover:underline">{dict.nav.services} →</a>
    </div>
    <div class="grid sm:grid-cols-2 gap-4">
      {services.map((s) => <ServiceCard lang={lang} service={s.data} />)}
    </div>
  </section>

  <!-- Process -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mb-2">
      {lang === 'sl' ? 'Postopek' : 'Process'}
    </h2>
    <p class="mb-8 text-ink-500 dark:text-ink-400">
      {lang === 'sl' ? 'Od briefa do dostave — osem korakov, en delovni tok.' : 'From brief to delivery — eight steps, one workflow.'}
    </p>
    <ProcessTimeline lang={lang} />
  </section>

  <!-- Projects -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="flex items-end justify-between gap-6 mb-8">
      <div>
        <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight">{dict.home.projects_heading}</h2>
        <p class="mt-2 text-ink-500 dark:text-ink-400">{dict.home.projects_sub}</p>
      </div>
      <a href={localePath(lang, '/portfolio')} class="hidden sm:inline text-sm text-accent-600 dark:text-accent-300 hover:underline">{dict.nav.portfolio} →</a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {projects.map((p) => <ProjectCard lang={lang} project={p.data} />)}
    </div>
  </section>

  <!-- Skills -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mb-2">{dict.home.skills_heading}</h2>
    <p class="mb-8 text-ink-500 dark:text-ink-400">{dict.home.skills_sub}</p>
    <SkillsCloud />
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="rounded-2xl bg-ink-900 dark:bg-ink-800 text-ink-50 p-10 sm:p-14 relative overflow-hidden">
      <div class="absolute -top-32 -right-32 w-96 h-96 bg-accent-500/30 rounded-full blur-3xl"></div>
      <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight max-w-xl">{dict.home.cta_heading}</h2>
      <p class="mt-3 text-ink-300 max-w-xl">{dict.home.cta_sub}</p>
      <a href={localePath(lang, '/order')} class="mt-6 inline-flex items-center px-5 py-3 rounded-md bg-accent-500 text-white font-medium hover:bg-accent-400 transition-colors">
        {dict.home.cta_button} →
      </a>
    </div>
  </section>
</BaseLayout>
