---
import { t, localePath, type Lang } from '~/i18n';
interface Props { lang: Lang }
const { lang } = Astro.props;
const dict = t(lang);
const year = new Date().getFullYear();
---
<footer class="border-t border-ink-200/70 dark:border-ink-800/70 mt-20">
  <div class="mx-auto max-w-6xl px-5 py-10 grid gap-6 sm:grid-cols-2 items-start text-sm text-ink-500 dark:text-ink-400">
    <div>
      <p class="font-display text-base text-ink-900 dark:text-ink-100 mb-1">Nace Kepa</p>
      <p>{dict.footer.tagline}</p>
      <p class="mt-3 text-xs">{dict.footer.made_with}</p>
    </div>
    <div class="sm:text-right space-y-2">
      <a href={localePath(lang, '/order')} class="inline-block px-4 py-2 rounded-md bg-accent-600 text-white hover:bg-accent-700 transition-colors">
        {dict.nav.order}
      </a>
      <p class="text-xs">© {year} Nace Kepa. {dict.footer.rights}</p>
    </div>
  </div>
</footer>
