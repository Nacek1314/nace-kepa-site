---
// Animated NK monogram.
// - Stroke draws in on first paint (path-length animation).
// - Continuous gradient sweep (sand → blue → navy).
// - Subtle dot pulse at the right.
interface Props {
  size?: number;
  class?: string;
}
const { size = 36, class: className = '' } = Astro.props;
---
<svg
  class={`nk-logo ${className}`}
  viewBox="0 0 64 64"
  width={size}
  height={size}
  role="img"
  aria-label="Nace Kepa"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <linearGradient id="nk-grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%"   stop-color="#bcb9ac" />
      <stop offset="50%"  stop-color="#5f8396" />
      <stop offset="100%" stop-color="#2f4a61" />
    </linearGradient>
  </defs>
  <!-- Frame -->
  <rect class="nk-frame" x="3" y="3" width="58" height="58" rx="14"
        fill="none" stroke="url(#nk-grad)" stroke-width="1.5" />
  <!-- N -->
  <path class="nk-stroke nk-n"
        d="M14 48 V16 L30 48 V16"
        fill="none" stroke="url(#nk-grad)"
        stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
  <!-- K -->
  <path class="nk-stroke nk-k"
        d="M38 16 V48 M38 32 L52 16 M38 32 L52 48"
        fill="none" stroke="url(#nk-grad)"
        stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
  <!-- Pulse dot -->
  <circle class="nk-dot" cx="56" cy="48" r="2" fill="#5f8396" />
</svg>

<style>
  .nk-logo {
    overflow: visible;
    display: inline-block;
    vertical-align: middle;
  }
  .nk-frame {
    transform-origin: center;
    animation: nk-frame-spin 18s linear infinite;
    opacity: 0.55;
  }
  .nk-stroke {
    stroke-dasharray: 200;
    stroke-dashoffset: 200;
    animation: nk-draw 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards,
               nk-glow 4s ease-in-out 1.6s infinite;
  }
  .nk-k {
    animation-delay: 0.35s, 1.85s;
    stroke-dasharray: 240;
    stroke-dashoffset: 240;
  }
  .nk-dot {
    transform-origin: 56px 48px;
    animation: nk-pulse 2.4s ease-in-out 1.6s infinite;
  }

  @keyframes nk-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes nk-glow {
    0%, 100% { filter: drop-shadow(0 0 0 rgba(95, 131, 150, 0)); }
    50%      { filter: drop-shadow(0 0 6px rgba(95, 131, 150, 0.55)); }
  }
  @keyframes nk-pulse {
    0%, 100% { transform: scale(1);   opacity: 1; }
    50%      { transform: scale(1.6); opacity: 0.4; }
  }
  @keyframes nk-frame-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Hover — speed up draw + brighten */
  :global(a:hover) .nk-stroke,
  :global(a:focus-visible) .nk-stroke {
    animation: nk-draw 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards,
               nk-glow 1.5s ease-in-out infinite;
  }
  :global(a:hover) .nk-frame {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .nk-frame { animation: none; }
    .nk-stroke {
      stroke-dashoffset: 0;
      animation: none;
    }
    .nk-dot { animation: none; }
  }
</style>
